{
  "expo": {
    "name": "Reunite",
    "slug": "reunite",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/reunite-icon.png",
    "scheme": "reunite",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.stillkindailab.reunite",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.stillkindailab.reunite",
      "adaptiveIcon": {
        "backgroundColor": "#EDD8C3",
        "foregroundImage": "./assets/images/reunite-icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/reunite-icon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-compressor",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/reunite-logo.png",
          "backgroundColor": "#EDD8C3",
          "android": {
            "image": "./assets/images/reunite-logo.png",
            "imageWidth": 200
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Reunite adds the photo you choose to this letter to your future self.",
          "cameraPermission": "Reunite uses the camera to capture a photo or short video to seal inside your letter.",
          "microphonePermission": "Reunite records sound for the short video you seal inside your letter."
        }
      ],
      "expo-image",
      [
        "@sentry/react-native/expo",
        {
          "organization": "diana-deng",
          "project": "reunite"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": "/app"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b7bc0908-093b-4062-9e93-343a0e12b535"
      }
    },
    "owner": "dianadeng",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b7bc0908-093b-4062-9e93-343a0e12b535"
    }
  }
}
